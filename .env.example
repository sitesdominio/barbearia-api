# ─────────────────────────────────────────────────────────────────────────────
# CONFIGURAÇÃO DA BARBEARIA API — Easypainel
# ─────────────────────────────────────────────────────────────────────────────
#
# IMPORTANTE: NÃO suba este arquivo para o git com dados reais.
# No Easypainel, configure essas variáveis em:
#   Seu App > Settings > Environment Variables
#

# Chave que o N8N vai enviar no header "x-api-key" para autenticar
# Gere uma chave forte: ex. use https://randomkeygen.com
API_KEY=coloque_uma_chave_forte_aqui_minimo_32_chars

# JSON completo da Service Account do Firebase
# Como obter:
#   1. Acesse console.firebase.google.com
#   2. Configurações do projeto (engrenagem) > Contas de serviço
#   3. Clique em "Gerar nova chave privada"
#   4. Baixe o arquivo .json
#   5. Abra o arquivo e cole TODO o conteúdo abaixo numa única linha
# ATENÇÃO: o valor deve ser o JSON completo, começando com { e terminando com }
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"barbearia-35f52","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@barbearia-35f52.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Porta da API (o Easypanel vai expor essa porta automaticamente)
PORT=3000
